{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "awesome-modern-ui",
  "homepage": "https://awesome-modern-ui.vercel.app",
  "items": [
    {
      "name": "agent-workflow",
      "type": "registry:item",
      "title": "Modern UI Agent Workflow",
      "description": "Reglas, proceso, stack y barra de calidad para que Claude Code y Codex construyan experiencias premium.",
      "files": [
        {
          "path": "AGENTS.md",
          "type": "registry:file",
          "target": "~/AGENTS.md"
        },
        {
          "path": "CLAUDE.md",
          "type": "registry:file",
          "target": "~/CLAUDE.md"
        },
        {
          "path": ".claude/commands/create-modern-site.md",
          "type": "registry:file",
          "target": "~/.claude/commands/create-modern-site.md"
        },
        {
          "path": ".codex/skills/modern-ui/SKILL.md",
          "type": "registry:file",
          "target": "~/.codex/skills/modern-ui/SKILL.md"
        },
        {
          "path": "docs/AI_WORKFLOW.md",
          "type": "registry:file",
          "target": "~/docs/AI_WORKFLOW.md"
        },
        {
          "path": "docs/BRIEF_TEMPLATE.md",
          "type": "registry:file",
          "target": "~/docs/BRIEF_TEMPLATE.md"
        },
        {
          "path": "docs/QUALITY_BAR.md",
          "type": "registry:file",
          "target": "~/docs/QUALITY_BAR.md"
        },
        {
          "path": "docs/STACK.md",
          "type": "registry:file",
          "target": "~/docs/STACK.md"
        }
      ]
    },
    {
      "name": "advanced-effects",
      "type": "registry:block",
      "title": "Advanced Effects Pack",
      "description": "GSAP, ScrollTrigger, SplitText, MorphSVG, Lenis y React Three Fiber con reduced motion y fallbacks.",
      "dependencies": [
        "@gsap/react@2.1.2",
        "@react-three/drei@10.7.7",
        "@react-three/fiber@9.6.1",
        "gsap@3.15.0",
        "lenis@1.3.23",
        "three@0.182.0"
      ],
      "devDependencies": [
        "@types/three@0.182.0"
      ],
      "files": [
        {
          "path": "packages/effects/src/use-reduced-motion.ts",
          "type": "registry:hook",
          "target": "@components/amui/effects/use-reduced-motion.ts"
        },
        {
          "path": "packages/effects/src/ambient-orb.tsx",
          "type": "registry:component",
          "target": "@components/amui/effects/ambient-orb.tsx"
        },
        {
          "path": "packages/effects/src/lenis-provider.tsx",
          "type": "registry:component",
          "target": "@components/amui/effects/lenis-provider.tsx"
        },
        {
          "path": "packages/effects/src/morphing-symbol.tsx",
          "type": "registry:component",
          "target": "@components/amui/effects/morphing-symbol.tsx"
        },
        {
          "path": "packages/effects/src/scroll-story.tsx",
          "type": "registry:component",
          "target": "@components/amui/effects/scroll-story.tsx"
        },
        {
          "path": "packages/effects/src/split-text-reveal.tsx",
          "type": "registry:component",
          "target": "@components/amui/effects/split-text-reveal.tsx"
        },
        {
          "path": "packages/effects/src/view-transition-link.tsx",
          "type": "registry:component",
          "target": "@components/amui/effects/view-transition-link.tsx"
        }
      ]
    }
  ]
}
